<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    
    <!-- Глазик - Показать/Скрыть WebView (всегда видна как иконка) -->
    <item
        android:id="@+id/action_toggle_webview"
        android:icon="@drawable/ic_visibility"
        android:title="Показать/Скрыть WebView"
        app:showAsAction="always" />
    
    <!-- Шестерёнка - Настройки (всегда видна как иконка) -->
    <item
        android:id="@+id/action_settings"
        android:icon="@drawable/ic_settings"
        android:title="Настройки"
        app:showAsAction="always" />
    
    <!-- Overflow menu items -->
    <item
        android:id="@+id/action_clear_form"
        android:title="Очистить форму"
        app:showAsAction="never" />
    <item
        android:id="@+id/action_logout"
        android:title="Выйти"
        app:showAsAction="never" />
</menu>
