<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- Main Application Theme - AMOLED Dark -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <item name="colorSecondary">@color/purple_neon</item>
        <item name="colorSecondaryVariant">@color/purple_primary</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_dark</item>
        
        <!-- Status Bar & Nav Bar -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/toolbar_background</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/background_dark</item>
        
        <!-- Text -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Components -->
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="colorControlActivated">@color/purple_primary</item>
        <item name="colorControlHighlight">@color/purple_dark</item>
        <item name="colorAccent">@color/purple_primary</item>
        
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="checkboxStyle">@style/Widget.App.CheckBox</item>
        
         <!-- Dialog/Menu Background -->
        <item name="android:colorBackgroundFloating">@color/background_elevated</item>
        <item name="alertDialogTheme">@style/Theme.Project4P.Dialog</item>
    </style>
    
    <!-- Toolbar Overlays -->
    <style name="Theme.Project4P.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="android:background">@color/toolbar_background</item>
        <item name="colorControlNormal">@color/white</item>
        <item name="titleTextColor">@color/white</item>
    </style>
    
    <style name="Theme.Project4P.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Dark">
        <item name="android:colorBackground">@color/background_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
     <style name="Theme.Project4P.Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:background">@color/background_elevated</item>
        <item name="colorSurface">@color/background_elevated</item>
    </style>

    <!-- UI Components -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.App.RoundedButton</item>
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ShapeAppearance.App.RoundedButton" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    
    <style name="ShapeAppearance.App.CapsuleButton" parent="ShapeAppearance.App.RoundedButton" />

    <style name="Widget.App.Button.Purple" parent="Widget.App.Button">
        <item name="backgroundTint">@color/purple_primary</item>
    </style>
    
    <style name="Widget.App.Button.Red" parent="Widget.App.Button">
        <item name="backgroundTint">@color/red_primary</item>
    </style>
    
    <style name="Widget.App.Button.Green" parent="Widget.App.Button">
        <item name="backgroundTint">@color/green_primary</item>
    </style>
    
    <style name="Widget.App.Button.Blue" parent="Widget.App.Button">
        <item name="backgroundTint">@color/blue_primary</item>
    </style>
    
    <style name="Widget.App.Button.BBCode" parent="Widget.App.Button">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="Widget.App.CheckBox" parent="Widget.MaterialComponents.CompoundButton.CheckBox">
        <item name="buttonTint">@color/checkbox_tint</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="HeaderTextStyle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="SubHeaderTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>